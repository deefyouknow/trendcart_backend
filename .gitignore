/target

# environment
.env
.env.*
!.env.example

# uploads (user-generated content)
/uploads/*
!/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/
*.swp
*.swo

# sqlx offline query data (regenerated by `cargo sqlx prepare`)
# Not needed since the backend uses runtime queries, not query! macros
.sqlx/

# AI agent config (must stay in .claude/ only)
CLAUDE.md
AGENTS.md
.claude/
.agents/
